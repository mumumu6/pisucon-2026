#!/usr/bin/env bash
set -Eeuo pipefail

TOOL_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# shellcheck source=../lib/common.sh
source "$TOOL_ROOT/lib/common.sh"
# shellcheck source=../lib/setup.sh
source "$TOOL_ROOT/lib/setup.sh"
# shellcheck source=../lib/share.sh
source "$TOOL_ROOT/lib/share.sh"
# shellcheck source=../lib/fleet.sh
source "$TOOL_ROOT/lib/fleet.sh"

case "${1:-help}" in
  help|-h|--help) usage; exit 0 ;;
  setup) command_setup; exit 0 ;;
esac

load_config

case "${1:-help}" in
  fleet) "command_fleet_${2:-help}" "${3:-}" ;;
  publish) command_publish "${2:-}" ;;
  *) fail "unknown command: $1" ;;
esac
