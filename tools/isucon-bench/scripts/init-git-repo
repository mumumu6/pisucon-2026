#!/usr/bin/env bash
# サーバー ~/ を git 初期化し、/etc → server-config 種まき → commit → push
# 必須: GIT_REPOSITORY GIT_VERSION GIT_USER_NAME GIT_USER_EMAIL MANAGED_ETC_PATHS
set -euo pipefail

[[ "${1:-}" == --full ]] || { echo "Usage: $0 --full" >&2; exit 1; }

ROOT="${INIT_GIT_ROOT:-$HOME}"
REPO="${GIT_REPOSITORY:?}"
BRANCH="${GIT_VERSION:?}"
NAME="${GIT_USER_NAME:?}"
EMAIL="${GIT_USER_EMAIL:?}"
MANAGED_ETC_PATHS="${MANAGED_ETC_PATHS:?}"

cd "$ROOT"
run() { echo "+ $*" >&2; "$@"; }

[[ -d .git ]] || run git init
run git config user.name "$NAME"
run git config user.email "$EMAIL"
git remote get-url origin >/dev/null 2>&1 \
  && run git remote set-url origin "$REPO" \
  || run git remote add origin "$REPO"

cat >.gitignore <<'EOF'
# histories / caches
/.*_history
/.*_logout
/.viminfo
/.lesshst
/.sudo_as_admin_successful
/.cache
/.local
/.config
/.npm
/.cargo
/.rustup
/.composer
/.bundle
/.gem
/.cpanm
/.perl-cpm
/.deno
/.xbuild
/.cmake

# secrets / ssh（デプロイ鍵は別途配置）
/.ssh
/.gitconfig

# logs / profiles
/log/
/logs/
*.log
*.prof

# deps / build
node_modules/
/go/pkg/

# 他言語実装（Go 以外は commit しない）
/webapp/php/
/webapp/ruby/
/webapp/python/
/webapp/perl/
/webapp/node/
/webapp/rust/
/webapp/java/
EOF

mkdir -p server-config
while IFS= read -r path; do
  [[ -z "$path" || "$path" == \#* ]] && continue
  dest="server-config$path"
  [[ -e "$dest" ]] && continue
  [[ -e "$path" ]] || {
    echo "エラー: managed_etc_paths の実体がありません: $path" >&2
    exit 1
  }

  echo "seed $path -> $dest"
  if [[ -f "$path" ]]; then
    sudo cp -n "$path" "${path}.orig" 2>/dev/null || true
    mkdir -p "$(dirname "$dest")"
    sudo cp "$path" "$dest"
  else
    mkdir -p "$dest"
    sudo rsync -a "${path}/" "${dest}/"
  fi
done <<<"$MANAGED_ETC_PATHS"
sudo chown -R "$(id -u):$(id -g)" server-config

run git add -A
if git diff --cached --quiet; then
  echo "git: unchanged"
else
  run git status --short
  run git commit -m "initial: $(hostname) home (+ server-config)"
fi

# リモートにブランチがあるときだけ pull（空 repo への初回 push を通す）
if git ls-remote --exit-code origin "refs/heads/$BRANCH" >/dev/null 2>&1; then
  run git pull origin "$BRANCH" --allow-unrelated-histories --no-edit
fi
run git push -u origin "HEAD:refs/heads/$BRANCH"
echo "done."
