#!/usr/bin/env bash
# 手元のベンチ結果 (REPORT.md) から GitHub Issue を作る。
# 使い方: publish [SESSION_ID|絶対パス]
#   SESSION 省略時は log/ 配下の最新セッション
set -Eeuo pipefail

tool="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
root="$(cd "$tool/../.." && pwd)"
inventory="${ANSIBLE_INVENTORY:-$tool/ansible/inventory.yml}"
log_root="${LOCAL_LOG_ROOT:-$root/log}"
session_arg="${1:-}"
max_bytes=58000 # Issue / comment のだいたいの上限対策

need() { command -v "$1" >/dev/null || { echo "$1 is required" >&2; exit 1; }; }
need ansible-inventory
need gh
need jq
[[ -f "$inventory" ]] || { echo "inventory not found: $inventory" >&2; exit 1; }

# inventory から reporter 1台の hostvars を取る
inv_json="$(ansible-inventory -i "$inventory" --list)"
reporter="$(jq -er '.reporter.hosts | select(length==1) | .[0]' <<<"$inv_json")" \
  || { echo "inventory の reporter はちょうど1台にしてください" >&2; exit 1; }
vars="$(jq -c --arg h "$reporter" '._meta.hostvars[$h]' <<<"$inv_json")"
repo="$(jq -er '.github_repository' <<<"$vars")" \
  || { echo "github_repository を group_vars に書いてください" >&2; exit 1; }
[[ "$(jq -r '.create_github_issue // true' <<<"$vars")" == true ]] \
  || { echo "create_github_issue=false のためスキップ"; exit 0; }

# 対象セッションディレクトリを決める
if [[ -n "$session_arg" ]]; then
  [[ "$session_arg" = /* ]] && session="$session_arg" || session="$log_root/$session_arg"
else
  session="$(find "$log_root" -mindepth 1 -maxdepth 1 -type d -printf '%T@ %p\n' \
    | sort -nr | head -1 | cut -d' ' -f2-)"
fi
[[ -n "${session:-}" && -d "$session" ]] || { echo "セッションが見つかりません" >&2; exit 1; }
report="$session/REPORT.md"
[[ -f "$report" ]] || { echo "REPORT.md がありません。先に make bench / collect" >&2; exit 1; }

# 本文は長すぎると弾かれるので頭だけ載せる
body="$(mktemp)"
trap 'rm -f "$body" "${cmt:-}"' EXIT
head -c "$max_bytes" "$report" >"$body"
truncated=false
if (( $(wc -c <"$report") > max_bytes )); then
  truncated=true
  printf '\n\n... truncated; 全文は手元の log/ を見てください。\n' >>"$body"
fi

title="ISUCON benchmark $(basename "$session")"
issue_url="$(gh issue create --repo "$repo" --title "$title" --body-file "$body")"

# 本文が切れたときだけ、各ホストの解析テキストをコメントで追記
if [[ "$truncated" == true ]]; then
  while IFS= read -r f; do
    cmt="$(mktemp)"
    {
      printf '## %s: %s\n\n```text\n' "$(basename "$f" .txt)" "$(basename "$(dirname "$f")")"
      head -c "$max_bytes" "$f"
      (( $(wc -c <"$f") > max_bytes )) && printf '\n... truncated\n'
      printf '\n```\n'
    } >"$cmt"
    gh issue comment "$issue_url" --body-file "$cmt"
    rm -f "$cmt"
    unset cmt
  done < <(find "$session" -mindepth 2 -maxdepth 2 -type f \
    \( -name 'alp.txt' -o -name 'pt-query-digest.txt' -o -name 'pprof.txt' \) | sort)
fi

echo "GitHub Issue created: $issue_url"
