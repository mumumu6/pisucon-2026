#!/usr/bin/env bash
# 全サーバーの netdata (127.0.0.1:19999) を SSH トンネルで手元に出す。
#   make netdata-view
# → isucon-1: http://localhost:19999, 次のホスト: 20000, …
#
# やっていること: ssh -N -L <local>:127.0.0.1:19999 user@host
# inventory の各ホストに ansible_host / ansible_user が必須（無ければエラー）。
set -euo pipefail

INV="$(cd "$(dirname "$0")/../ansible" && pwd)/inventory.yml"
BASE_PORT="${NETDATA_LOCAL_BASE_PORT:-19999}"

i=0
while IFS=$'\t' read -r name ip user; do
  lport=$((BASE_PORT + i))
  echo "http://localhost:${lport}  ($name)"
  ssh -o ExitOnForwardFailure=yes -o ServerAliveInterval=30 \
    -N -L "${lport}:127.0.0.1:19999" "${user}@${ip}" &
  i=$((i + 1))
done < <(
  # inventory JSON から「名前 / IP / ユーザー」をタブ区切りで出す
  ansible-inventory -i "$INV" --list | jq -r '
    ._meta.hostvars | to_entries[]
    | if (.value.ansible_host|not) or (.value.ansible_user|not) then
        error("ansible_host / ansible_user が必要: \(.key)")
      else . end
    | [.key, .value.ansible_host, .value.ansible_user] | @tsv
  ' | sort
)
[[ "$i" -gt 0 ]] || { echo "inventory にホストがありません" >&2; exit 1; }
wait
