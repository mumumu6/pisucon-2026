#!/usr/bin/env bash
set -Eeuo pipefail

# 使い方:
#   make netdata-view                  # reporter (または LOCAL_PORT=19999)
#   make netdata-view HOST=isucon-2    # ホストごとにローカルポートをずらす
#   make netdata-view HOST=all         # 全ホストを同時にトンネル
#
# Grafanaは不要。ブラウザで localhost:19999 / :20000 を並べて見る。

tool_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
inventory="${ANSIBLE_INVENTORY:-$tool_root/ansible/inventory.yml}"
requested_host="${1:-}"
base_port="${NETDATA_LOCAL_BASE_PORT:-19999}"

command -v ansible-inventory >/dev/null || { echo "ansible-inventory is required" >&2; exit 1; }
command -v jq >/dev/null || { echo "jq is required" >&2; exit 1; }

inventory_json="$(ansible-inventory --inventory "$inventory" --list)"
mapfile -t all_hosts < <(jq -r '._meta.hostvars | keys[]' <<< "$inventory_json" | sort)

local_port_for() {
  local host="$1"
  local i
  for i in "${!all_hosts[@]}"; do
    if [[ "${all_hosts[$i]}" == "$host" ]]; then
      echo $((base_port + i))
      return
    fi
  done
  echo "unknown inventory host: $host" >&2
  return 1
}

tunnel_one() {
  local host="$1"
  local foreground="${2:-1}"
  local connection address user ssh_port local_port
  local -a ssh_args

  connection="$(jq -er --arg host "$host" '._meta.hostvars[$host]' <<< "$inventory_json")" || {
    echo "unknown inventory host: $host" >&2
    return 1
  }
  address="$(jq -r --arg host "$host" '.ansible_host // $host' <<< "$connection")"
  user="$(jq -r '.ansible_user // "isucon"' <<< "$connection")"
  ssh_port="$(jq -r '.ansible_port // empty' <<< "$connection")"
  local_port="$(local_port_for "$host")"

  if ss -ltn 2>/dev/null | grep -qE ":${local_port}\\s"; then
    echo "Netdata already tunneled: http://localhost:$local_port ($host)"
    return 0
  fi

  ssh_args=(-o ExitOnForwardFailure=yes -o ServerAliveInterval=30 -N -L "${local_port}:127.0.0.1:19999")
  [[ -z "$ssh_port" ]] || ssh_args+=(-p "$ssh_port")

  echo "Netdata: http://localhost:$local_port ($host)"
  if [[ "$foreground" == "1" ]]; then
    exec ssh "${ssh_args[@]}" "$user@$address"
  fi
  ssh "${ssh_args[@]}" "$user@$address" &
  echo "  pid $! (stop: kill $!)"
}

if [[ "$requested_host" == "all" ]]; then
  [[ ${#all_hosts[@]} -gt 0 ]] || { echo "no hosts in inventory" >&2; exit 1; }
  echo "Opening Netdata tunnels for all hosts (Ctrl+C stops this waiter; tunnels keep running in background)."
  for host in "${all_hosts[@]}"; do
    tunnel_one "$host" 0
  done
  echo
  echo "Open in browser:"
  for host in "${all_hosts[@]}"; do
    echo "  http://localhost:$(local_port_for "$host")  # $host"
  done
  wait
  exit 0
fi

if [[ -z "$requested_host" ]]; then
  if curl -fsS --max-time 1 "http://127.0.0.1:${base_port}/api/v1/info" >/dev/null 2>&1; then
    echo "Netdata is already available: http://localhost:${base_port}"
    exit 0
  fi
  requested_host="$(jq -r '.reporter.hosts[0] // empty' <<< "$inventory_json")"
fi

[[ -n "$requested_host" ]] || { echo "HOST is required because reporter is not configured" >&2; exit 1; }
tunnel_one "$requested_host" 1
