#!/usr/bin/env bash
set -Eeuo pipefail

repository_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
template="$repository_root/tools/isucon-bench/ansible/templates/pprof.go.j2"
vars_file="$repository_root/tools/isucon-bench/ansible/group_vars/all.yml"
relative_target="webapp/go/pprof.go"
pprof_listen="127.0.0.1:6060"
if [[ -f "$vars_file" ]]; then
  extracted_path="$(sed -nE 's/^local_pprof_relative:[[:space:]]*([^#[:space:]]+).*/\1/p' "$vars_file" | head -1)"
  [[ -n "$extracted_path" ]] && relative_target="$extracted_path"
  extracted="$(sed -nE 's/^pprof_listen:[[:space:]]*"([^"]+)".*/\1/p' "$vars_file" | head -1)"
  [[ -n "$extracted" ]] && pprof_listen="$extracted"
fi
target="$repository_root/$relative_target"
state="${1:-}"

render_pprof() {
  sed "s/{{ pprof_listen }}/${pprof_listen//\//\\/}/g" "$template"
}

case "$state" in
  on)
    mkdir -p "$(dirname "$target")"
    render_pprof >"$target"
    chmod 0644 "$target"
    commit_message="chore: enable pprof"
    ;;
  off)
    rm -f "$target"
    commit_message="chore: disable pprof"
    ;;
  *)
    echo "usage: $0 on|off" >&2
    exit 2
    ;;
esac

if [ -e "$target" ] || git -C "$repository_root" ls-files --error-unmatch -- "$relative_target" >/dev/null 2>&1; then
  git -C "$repository_root" add --all -- "$relative_target"
  if ! git -C "$repository_root" diff --cached --quiet -- "$relative_target"; then
    git -C "$repository_root" commit --only -m "$commit_message" -- "$relative_target"
    branch="$(git -C "$repository_root" branch --show-current)"
    if [ -z "$branch" ]; then
      echo "現在のGitブランチを取得できません" >&2
      exit 1
    fi
    git -C "$repository_root" push origin "$branch"
  fi
fi
