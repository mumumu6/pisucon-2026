#!/usr/bin/env bash
# 手元リポジトリの pprof.go を on/off し、そのファイルだけ commit & push する。
# 使い方: toggle-pprof on|off
set -Eeuo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
vars="$root/tools/isucon-bench/ansible/group_vars/all.yml"
template="$root/tools/isucon-bench/ansible/templates/pprof.go.j2"
state="${1:-}"

read_var() {
  local key="$1"
  [[ -f "$vars" ]] || return 0
  sed -nE "s/^${key}:[[:space:]]*\"?([^\"#[:space:]]+)\"?.*/\1/p" "$vars" | head -1
}

pprof_filename="$(read_var pprof_filename)"
[[ -z "$pprof_filename" ]] && pprof_filename=pprof.go

rel="webapp/go/${pprof_filename}"
target="$root/$rel"

case "$state" in
  on)
    mkdir -p "$(dirname "$target")"
    install -m 0644 "$template" "$target"
    msg="chore: enable pprof"
    ;;
  off)
    rm -f "$target"
    msg="chore: disable pprof"
    ;;
  *)
    echo "usage: $0 on|off" >&2
    exit 2
    ;;
esac

git -C "$root" ls-files --error-unmatch -- "$rel" >/dev/null 2>&1 || [[ -e "$target" ]] || exit 0
git -C "$root" add --all -- "$rel"
git -C "$root" diff --cached --quiet -- "$rel" && exit 0

branch="$(git -C "$root" branch --show-current)"
[[ -n "$branch" ]] || { echo "現在のブランチを取得できません" >&2; exit 1; }
git -C "$root" commit --only -m "$msg" -- "$rel"
git -C "$root" push origin "$branch"
