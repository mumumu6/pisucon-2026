{#
  MariaDB 性能設定 → mysql_performance_cnf（例: /etc/mysql/mariadb.conf.d/99-isucon-performance.cnf）
  数値をいじるときはこのファイルを直接直して make mysql-tune。

  Jinja 変数（group_vars/all.yml）:
    slow_log … スロークエリログのファイルパス（bench の truncate / pt-query-digest も同じパスを使う）
#}
# OS/電源断時、直近およそ1秒分の更新が失われる可能性がある（flush_log_at_trx_commit=2）。
# bind-address は 50-server.cnf の 127.0.0.1 を上書きする（ファイル名 99- で後勝ち）。

[mysqld]
# 常に全インターフェースで待受（分離構成でも手を入れなくてよい。1台でも害は少ない）
bind-address = 0.0.0.0
slow_query_log = 1
# slow_log: スローログの出力先（group_vars と一致させる）
slow_query_log_file = {{ slow_log }}
# 0 ならほぼ全クエリを slow log へ（計測用。最終計測前は monitor off で止める）
long_query_time = 0
log_output = FILE

[mariadb]
# COMMIT 時の redo fsync 頻度。2=約1秒ごと（速いが耐久性↓）
innodb_flush_log_at_trx_commit = 2
# レプリカ無し想定でバイナリログを切る（I/O 削減）
skip-log-bin

# InnoDB のメインキャッシュ。DB 専用機のメモリに合わせて調整
innodb_buffer_pool_size = 2G
# buffer pool の分割数（目安: だいたい 1 インスタンス ≒ 1GB）
innodb_buffer_pool_instances = 2
# redo を書く前のメモリバッファ
innodb_log_buffer_size = 64M
# redo ログファイルサイズ。大きいほど checkpoint 頻度↓（再起動時に反映）
innodb_log_file_size = 512M
# OS ページキャッシュとの二重化を避ける
innodb_flush_method = O_DIRECT
# dirty page 書き出しペース（NVMe なら高め）
innodb_io_capacity = 2000
innodb_io_capacity_max = 4000
# 最大同時接続数
max_connections = 1000
