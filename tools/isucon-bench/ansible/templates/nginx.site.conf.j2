{#
  nginx サイト設定 → /etc/nginx/conf.d/<app_name>.conf

  Jinja / set_fact（topology-facts.yml 経由）:
    app_unix_socket       … 同居時の unix socket パス
    access_log            … access log パス
    frontend_public_dir   … 静的ファイル root
    nginx_app_colocated   … この nginx ホストが app も持つか
    groups['app']         … 分離時は各ホストの private_ip を upstream に列挙
    app_listen_port       … 分離時の TCP ポート（group_vars、既定 3000）

  location / gzip は大会に合わせてこのファイルを直接編集する。
#}

log_format ltsv "time:$time_local"
                "\thost:$remote_addr"
                "\tforwardedfor:$http_x_forwarded_for"
                "\treq:$request"
                "\tstatus:$status"
                "\tmethod:$request_method"
                "\turi:$request_uri"
                "\tsize:$body_bytes_sent"
                "\treferer:$http_referer"
                "\tua:$http_user_agent"
                "\treqtime:$request_time"
                "\tapptime:$upstream_response_time"
                "\tvhost:$host";

# proxy_pass http://app; から参照。同居なら unix、分離なら inventory の private_ip。
# app が複数ホストなら、分離時は groups['app'] 全部を upstream に並べる。
upstream app {
{% if nginx_app_colocated | bool %}
    # nginx と app が同一ホスト → unix socket
    server unix:{{ app_unix_socket }};
{% else %}
{% for host in groups['app'] %}
    # {{ host }} ← inventory.yml の private_ip（無ければ ansible_host）
    server {{ hostvars[host].private_ip | default(hostvars[host].ansible_host) }}:{{ app_listen_port | default(3000) }};
{% endfor %}
{% endif %}
    keepalive 256;
}

server {
    listen 80;
    listen [::]:80;
    server_name _;

    client_body_buffer_size 256k;
    access_log {{ access_log }} ltsv;

    gzip on;
    gzip_comp_level 1;
    gzip_min_length 1024;
    gzip_types application/json;
    gzip_vary on;

    root {{ frontend_public_dir }};
    index index.html;

    location ^~ /assets/ {
        try_files $uri =404;
        access_log off;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    location = /initialize {
        proxy_pass http://app;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ^~ /api/ {
        proxy_pass http://app;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
