- Reporter: `{{ groups['reporter'][0] }}`
- Git revision: `{{ lookup('ansible.builtin.file', local_session_dir + '/' + groups['reporter'][0] + '/git-revision.txt', errors='ignore') | default('unknown', true) }}`
- Score: `{{ lookup('ansible.builtin.file', local_session_dir + '/' + groups['reporter'][0] + '/score.txt', errors='ignore') | default('unknown', true) }}`

