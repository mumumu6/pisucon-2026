upstream isucondition_app {
{% if nginx_app_unix_socket | length > 0 %}
    server unix:{{ nginx_app_unix_socket }};
{% else %}
    server {{ nginx_app_backend_host }}:{{ nginx_app_port }};
{% endif %}
    keepalive {{ nginx_upstream_keepalive }};
}

server {
    listen {{ nginx_listen_port }};
    listen [::]:{{ nginx_listen_port }};
    server_name _;

    client_body_buffer_size {{ nginx_client_body_buffer_size }};

    # trendなどのJSONレスポンスを軽量圧縮し、転送量とGoの書き込み負荷を減らす。
    # gzip_proxied は付けない（proxy APIは圧縮しない。ベンチはAEを送らない想定）。
    gzip on;
    gzip_comp_level 1;
    gzip_min_length 1024;
    gzip_types application/json;
    gzip_vary on;

    root {{ frontend_public_dir }};
    index index.html;

    # Vite がファイル名へ内容ハッシュを含めるため、長期キャッシュしてよい。
    location ^~ /assets/ {
        try_files $uri =404;
        access_log off;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # 初期化と API だけを Go アプリケーションへ渡す。
    location = /initialize {
        proxy_pass http://isucondition_app;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ^~ /api/ {
        proxy_pass http://isucondition_app;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # React Router の画面URLは index.html へフォールバックする。
    location / {
        try_files $uri $uri/ /index.html;
    }
}
