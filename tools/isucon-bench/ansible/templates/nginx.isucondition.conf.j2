sendfile on;
tcp_nopush on;
tcp_nodelay on;
keepalive_timeout {{ nginx_keepalive_timeout }};
keepalive_requests {{ nginx_keepalive_requests }};

server {
    listen {{ nginx_listen_port }} reuseport;
    listen [::]:{{ nginx_listen_port }};
{% if nginx_enable_https %}
    listen {{ nginx_https_port }} ssl http2 reuseport;
    listen [::]:{{ nginx_https_port }} ssl http2;

    ssl_certificate {{ nginx_ssl_certificate }};
    ssl_certificate_key {{ nginx_ssl_certificate_key }};
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets on;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
{% endif %}

    server_name _;

    client_body_buffer_size {{ nginx_client_body_buffer_size }};
    client_max_body_size {{ nginx_client_max_body_size }};

    # Accept-Encoding: gzip のクライアント向け。API(proxy)は gzip_proxied が必要。
    gzip on;
    gzip_comp_level 1;
    gzip_min_length 1024;
    gzip_proxied any;
    gzip_types
        application/json
        text/css
        text/javascript
        application/javascript
        application/x-javascript
        application/xml
        text/plain
        image/svg+xml;
    gzip_vary on;

    open_file_cache max=10000 inactive=60s;
    open_file_cache_valid 60s;
    open_file_cache_min_uses 1;
    open_file_cache_errors on;

    root {{ frontend_public_dir }};
    index index.html;

    location ^~ /assets/ {
        try_files $uri =404;
        access_log off;
        expires 1y;
        add_header Cache-Control "public, immutable";
        gzip_static on;
    }

    location = /initialize {
        proxy_pass http://{{ nginx_app_backend_host }}:{{ nginx_app_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ^~ /api/ {
        proxy_pass http://{{ nginx_app_backend_host }}:{{ nginx_app_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
