{#
  アプリ systemd の drop-in → /etc/systemd/system/<app_service>.d/override.conf

  Jinja 変数（group_vars/all.yml）:
    app_runtime_directory … RuntimeDirectory= の値。/run/<この名前>/ が作られる（例: isucondition）
    app_unix_socket       … アプリが listen する socket パス。nginx の upstream と同じにする

  GOGC / GOMEMLIMIT / LimitNOFILE は直書き。変えたいときはこのファイルを編集。
#}
[Service]
# 同時接続向けの FD 上限
LimitNOFILE=65535
# /run/<app_runtime_directory>/ を用意（socket 置き場）
RuntimeDirectory={{ app_runtime_directory }}
RuntimeDirectoryMode=0755
# アプリ側が読む socket パス（多くの ISUCON 実装がこの環境変数を見る）
Environment=SERVER_APP_SOCK={{ app_unix_socket }}
# Go GC。大きいほど GC 頻度↓（メモリに余裕があるとき）
Environment=GOGC=400
# Go ヒープのソフト上限
Environment=GOMEMLIMIT=2GiB
