{#
  アプリ systemd drop-in → /etc/systemd/system/<app_service>.d/override.conf

  Jinja / set_fact:
    app_runtime_directory … /run/<名前>/
    app_unix_socket       … unix socket パス
    app_listen_unix       … このホストに nginx もいるか（いれば unix、いなければ TCP）
    app_listen_port       … TCP 待受ポート（既定 3000）
#}
[Service]
LimitNOFILE=65535
RuntimeDirectory={{ app_runtime_directory }}
RuntimeDirectoryMode=0755
{% if app_listen_unix | default(true) | bool %}
# nginx と同居 → unix socket（nginx upstream と同じパス）
Environment=SERVER_APP_SOCK={{ app_unix_socket }}
{% else %}
# nginx が別ホスト → TCP 待受（inventory の役割から自動判定）
Environment=SERVER_APP_PORT={{ app_listen_port | default(3000) }}
{% endif %}
Environment=GOGC=400
Environment=GOMEMLIMIT=2GiB
