{#
  アプリ用 env.sh → remote_project_root/env.sh（多くの ISUCON 実装が source する）

  Jinja / set_fact:
    app_db_colocated … app と db が同一ホストか
    db_backend_ip    … db の private_ip（inventory）
    mysql_*          … group_vars の接続情報
    app_env_extra    … 大会固有の追加行（任意）
#}
# Ansible 管理。DB ホストは inventory の db グループ private_ip から自動設定。
{% if app_db_colocated | bool %}
MYSQL_HOST="127.0.0.1"
{% else %}
MYSQL_HOST="{{ db_backend_ip }}"
{% endif %}
MYSQL_PORT={{ mysql_port | default(3306) }}
MYSQL_USER={{ mysql_user | default('isucon') }}
MYSQL_DBNAME={{ mysql_dbname | default(app_name) }}
MYSQL_PASS={{ mysql_password | default('isucon') }}
{% if app_env_extra is defined and app_env_extra | length > 0 %}
{{ app_env_extra }}
{% endif %}
