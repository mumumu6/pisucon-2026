{#
  env.sh がサーバーに無いときだけ使う最小テンプレ。
  既存ファイルがある場合は tasks/app/env.yml が MYSQL_HOST のみ書き換える。

  Jinja / set_fact:
    app_db_colocated … app と db が同一ホストか
    db_backend_ip    … db の private_ip（inventory）
    mysql_*          … group_vars
    app_env_extra    … 大会固有の追加行（任意）
#}
MYSQL_HOST="{% if app_db_colocated | bool %}127.0.0.1{% else %}{{ db_backend_ip }}{% endif %}"
MYSQL_PORT={{ mysql_port | default(3306) }}
MYSQL_USER={{ mysql_user | default('isucon') }}
MYSQL_DBNAME={{ mysql_dbname | default(app_name) }}
MYSQL_PASS={{ mysql_password | default('isucon') }}
{% if app_env_extra is defined and (app_env_extra | trim | length) > 0 %}
{{ app_env_extra | trim }}
{% endif %}
