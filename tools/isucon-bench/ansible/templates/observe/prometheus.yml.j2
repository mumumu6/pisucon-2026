global:
  scrape_interval: {{ observe_scrape_interval | default('1s') }}
  evaluation_interval: {{ observe_scrape_interval | default('1s') }}
  scrape_timeout: 900ms

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["127.0.0.1:{{ observe_prometheus_port }}"]

  - job_name: node
    static_configs:
{% for host in groups['all'] | unique %}
      - targets: ["{{ hostvars[host].private_ip | default(hostvars[host].ansible_host) }}:{{ observe_node_exporter_port }}"]
        labels:
          instance: "{{ host }}"
{% endfor %}

  - job_name: mysqld
    static_configs:
{% for host in groups.get('db', []) | unique %}
      - targets: ["{{ hostvars[host].private_ip | default(hostvars[host].ansible_host) }}:{{ observe_mysqld_exporter_port }}"]
        labels:
          instance: "{{ host }}"
{% endfor %}

  - job_name: alloy
    static_configs:
{% for host in groups['all'] | unique %}
      - targets: ["{{ hostvars[host].private_ip | default(hostvars[host].ansible_host) }}:{{ observe_alloy_metrics_port | default(12345) }}"]
        labels:
          instance: "{{ host }}"
{% endfor %}
