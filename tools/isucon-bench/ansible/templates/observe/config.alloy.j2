// Alloy: journal + error log (+ 任意で access.log) → Loki
// access.log からは API 別 RPS 用メトリクスも出す
logging {
  level  = "warn"
  format = "logfmt"
}

loki.write "default" {
  endpoint {
    url        = "http://{{ observe_loki_push_host }}:{{ observe_loki_port }}/loki/api/v1/push"
    batch_wait = "30s"
    batch_size = "2MiB"
  }
}

{% if inventory_hostname in groups.get('app', []) %}
loki.source.journal "app" {
  matches     = "_SYSTEMD_UNIT={{ app_service }}"
  forward_to  = [loki.write.default.receiver]
  labels = {
    host = "{{ inventory_hostname }}",
    job  = "app",
    unit = "{{ app_service }}",
  }
}
{% endif %}

{% if inventory_hostname in groups.get('nginx', []) %}
loki.source.journal "nginx" {
  matches     = "_SYSTEMD_UNIT=nginx.service"
  forward_to  = [loki.write.default.receiver]
  labels = {
    host = "{{ inventory_hostname }}",
    job  = "nginx",
    unit = "nginx.service",
  }
}

local.file_match "nginx_error" {
  path_targets = [
    {
      "__path__" = "/var/log/nginx/error.log",
      "job"      = "nginx-error",
      "host"     = "{{ inventory_hostname }}",
    },
  ]
}

loki.source.file "nginx_error" {
  targets    = local.file_match.nginx_error.targets
  forward_to = [loki.write.default.receiver]
}

{% if observe_ship_access_log | default(true) | bool %}
local.file_match "nginx_access" {
  path_targets = [
    {
      "__path__" = "{{ access_log }}",
      "job"      = "nginx-access",
      "host"     = "{{ inventory_hostname }}",
    },
  ]
}

loki.source.file "nginx_access" {
  targets       = local.file_match.nginx_access.targets
  forward_to    = [loki.process.nginx_access.receiver]
  tail_from_end = true
}

loki.process "nginx_access" {
  forward_to = [loki.write.default.receiver]

{% for drop in access_log_drop_patterns | default([]) %}
  stage.drop {
    expression          = {{ drop.expression | to_json }}
    drop_counter_reason = {{ drop.reason | default('dropped') | to_json }}
  }
{% endfor %}

  // LTSV: クエリを除いた path だけ uri に入れる
  stage.regex {
    expression = "status:(?P<status>[^\\t]+).*method:(?P<method>[^\\t]+).*uri:(?P<uri>[^\\t?]+)(?:\\?[^\\t]*)?.*reqtime:(?P<reqtime>[^\\t]+)"
  }

{% for norm in access_log_uri_normalizations | default([]) %}
  stage.replace {
    expression = {{ norm.expression | to_json }}
    source     = "uri"
    replace    = {{ norm.replace | to_json }}
  }
{% endfor %}

  // メトリクス用ラベル（このあと Loki 向けには落とす）
  stage.labels {
    values = {
      method = "",
      uri    = "",
      status = "",
    }
  }

  stage.metrics {
    metric.counter {
      name              = "nginx_http_requests_total"
      description       = "nginx access log requests"
      prefix            = "isucon_"
      match_all         = true
      action            = "inc"
      max_idle_duration = "24h0m0s"
    }

    metric.histogram {
      name              = "nginx_http_request_duration_seconds"
      description       = "nginx access log reqtime"
      prefix            = "isucon_"
      source            = "reqtime"
      buckets           = [0.001, 0.005, 0.01, 0.025, 0.05, 0.1, 0.25, 0.5, 1.0, 2.5, 5.0]
      max_idle_duration = "24h0m0s"
    }
  }

  // Loki ストリーム爆発防止（method/uri/status はメトリクス専用）
  stage.label_drop {
    values = ["method", "uri", "status"]
  }
}
{% endif %}
{% endif %}

{% if inventory_hostname in groups.get('db', []) %}
loki.source.journal "mariadb" {
  matches     = "_SYSTEMD_UNIT={{ mysql_service }}.service"
  forward_to  = [loki.write.default.receiver]
  labels = {
    host = "{{ inventory_hostname }}",
    job  = "mariadb",
    unit = "{{ mysql_service }}.service",
  }
}

local.file_match "mysql_error" {
  path_targets = [
    {
      "__path__" = "/var/log/mysql/error.log",
      "job"      = "mysql-error",
      "host"     = "{{ inventory_hostname }}",
    },
  ]
}

loki.source.file "mysql_error" {
  targets    = local.file_match.mysql_error.targets
  forward_to = [loki.write.default.receiver]
}
{% endif %}
