[Unit]
Description=MySQL / MariaDB Prometheus Exporter (ISUCON observe)
After=network-online.target {{ mysql_service }}.service
Wants=network-online.target

[Service]
Type=simple
User=nobody
Group=nogroup
ExecStart={{ observe_root }}/bin/mysqld_exporter \
  --config.my-cnf={{ observe_root }}/mysqld_exporter.cnf \
  --web.listen-address={{ private_ip | default('0.0.0.0') }}:{{ observe_mysqld_exporter_port }}
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
