# reporter 上の観測スタック。host ネットワークで private_ip 経由の scrape / push を簡単にする。
services:
  prometheus:
    image: {{ prometheus_image }}
    container_name: isucon-prometheus
    network_mode: host
    restart: unless-stopped
    volumes:
      - {{ observe_compose_dir }}/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - {{ observe_root }}/data/prometheus:/prometheus
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --storage.tsdb.path=/prometheus
      - --storage.tsdb.retention.time=24h
      - --web.listen-address=127.0.0.1:{{ observe_prometheus_port }}

  loki:
    image: {{ loki_image }}
    container_name: isucon-loki
    network_mode: host
    restart: unless-stopped
    volumes:
      - {{ observe_compose_dir }}/loki-config.yml:/etc/loki/config.yml:ro
      - {{ observe_root }}/data/loki:/loki
    command:
      - -config.file=/etc/loki/config.yml

  grafana:
    image: {{ grafana_image }}
    container_name: isucon-grafana
    network_mode: host
    restart: unless-stopped
    environment:
      GF_SERVER_HTTP_ADDR: "127.0.0.1"
      GF_SERVER_HTTP_PORT: "{{ observe_grafana_port }}"
      GF_AUTH_ANONYMOUS_ENABLED: "true"
      GF_AUTH_ANONYMOUS_ORG_ROLE: Admin
      GF_AUTH_DISABLE_LOGIN_FORM: "true"
      GF_USERS_DEFAULT_THEME: dark
      GF_SECURITY_ADMIN_PASSWORD: isucon
    volumes:
      - {{ observe_root }}/data/grafana:/var/lib/grafana
      - {{ observe_compose_dir }}/grafana/provisioning:/etc/grafana/provisioning:ro
