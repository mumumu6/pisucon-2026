# ---- 配線: alp 用 ltsv ログ（消すと make bench の解析が壊れる）----
log_format ltsv "time:$time_local"
                "\thost:$remote_addr"
                "\tforwardedfor:$http_x_forwarded_for"
                "\treq:$request"
                "\tstatus:$status"
                "\tmethod:$request_method"
                "\turi:$request_uri"
                "\tsize:$body_bytes_sent"
                "\treferer:$http_referer"
                "\tua:$http_user_agent"
                "\treqtime:$request_time"
                "\tapptime:$upstream_response_time"
                "\tvhost:$host";

# ---- チューニング: nginx→app のコネクション使い回し ----
# サイト設定側の proxy_pass を upstream 名に変え、以下を有効にする。
# proxy_http_version 1.1; proxy_set_header Connection ""; もセットで必要。
# unix socket 化はさらに速い（app 側 override.conf の SERVER_APP_SOCK とセット）。
# upstream app {
#     server 127.0.0.1:3000;
#     # server unix:{{ app_unix_socket }};
#     keepalive 256;
# }

# ---- チューニング: JSON レスポンス圧縮（帯域ネックのとき。CPU とトレード）----
# gzip on;
# gzip_comp_level 1;
# gzip_min_length 1024;
# gzip_types application/json;
# gzip_vary on;

# ---- チューニング: 大きい POST ボディをメモリで受ける（ディスク書き込み回避）----
# client_body_buffer_size 256k;

# ---- チューニング: 静的ファイルのブラウザキャッシュはサイト設定の server ブロック側で ----
