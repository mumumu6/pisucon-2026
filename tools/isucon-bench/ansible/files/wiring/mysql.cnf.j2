[mysqld]
# ---- 配線: slow query 計測（make bench の pt-query-digest が読む。on/off は monitor が制御）----
slow_query_log = 1
slow_query_log_file = {{ slow_log }}
long_query_time = {{ mysql_slow_query_time }}
log_output = FILE
# ---- 配線: DB 分離時に他ホストから接続を受ける（1台構成でも無害。同名キーは後勝ち）----
bind-address = 0.0.0.0

# ---- チューニング: InnoDB のメインキャッシュ。DB 機の空きメモリの 6〜8 割。まず最初に試す価値あり ----
# innodb_buffer_pool_size = 2G
# innodb_buffer_pool_instances = 2

# ---- チューニング: COMMIT ごとの fsync をやめ約1秒ごとに（書き込みが多いと大きく効く。電源断で直近1秒喪失）----
# innodb_flush_log_at_trx_commit = 2

# ---- チューニング: バイナリログを切って I/O 削減（レプリカを作らない前提）----
# skip-log-bin

# ---- チューニング: redo ログを大きくして checkpoint 頻度を下げる ----
# innodb_log_buffer_size = 64M
# innodb_log_file_size = 512M

# ---- チューニング: OS ページキャッシュとの二重化を避ける ----
# innodb_flush_method = O_DIRECT

# ---- チューニング: dirty page 書き出しペース（NVMe なら高め）----
# innodb_io_capacity = 2000
# innodb_io_capacity_max = 4000

# ---- チューニング: 最大同時接続数（Too many connections が出たら）----
# max_connections = 1000
